@model List<ServisRacunara.DAL.Entiteti.Klijent>

<a asp-action="Dodaj" class="btn btn-success mb-3">
    Dodaj klijenta
</a>

<h2>Lista klijenata</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Ime</th>
            <th>Prezime</th>
            <th>Telefon</th>
            <th>Email</th>
            <th>Akcije</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var klijent in Model)
        {
            <tr>
                <td>@klijent.Ime</td>
                <td>@klijent.Prezime</td>
                <td>@klijent.Telefon</td>
                <td>@klijent.Email</td>

                <td>
                    <a asp-action="Izmeni"
                       asp-route-id="@klijent.Id"
                       class="btn btn-warning btn-sm">
                        Izmeni
                    </a>

                    <a asp-action="Obrisi"
                       asp-route-id="@klijent.Id"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('Da li ste sigurni da želite da obrišete klijenta?')">
                        Obriši
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>