@model List<ServisRacunara.DAL.Entiteti.Uredjaj>

<a asp-action="Dodaj" class="btn btn-success mb-3">
    Dodaj uređaj
</a>

<h2>Lista uređaja</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Naziv</th>
            <th>Model</th>
            <th>Klijent</th>
            <th>Akcije</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var uredjaj in Model)
        {
            <tr>
                <td>@uredjaj.Naziv</td>
                <td>@uredjaj.Model</td>
                <td>@uredjaj.Klijent.Ime @uredjaj.Klijent.Prezime</td>

                <td>
                    <a asp-action="Izmeni"
                       asp-route-id="@uredjaj.Id"
                       class="btn btn-warning btn-sm">
                        Izmeni
                    </a>

                    <a asp-action="Obrisi"
                       asp-route-id="@uredjaj.Id"
                       class="btn btn-danger btn-sm">
                        Obriši
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>